{
  "name": "utslrc/api",
  "type": "project",
  "description": "UT_API backend rebuilt as a Laravel application with security and maintainability improvements.",
  "require": {
    "php": "^8.0",
    "laravel/framework": "^11.0",
    "laravel/sanctum": "^3.4"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "scripts": {
    "test": [
      "php -l public/index.php"
    ]
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
